# Target Config
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# Set Firmware Size
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=1024  # 增加分区大小以适应DPDK

# Firmware Type
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y

# Applications
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-app-filemanager=y

# Software
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_kmod-sched-connmark=y
CONFIG_PACKAGE_kmod-nft-netdev=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-ipt-ipopt=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-ipt-nat-extra=y
CONFIG_TCP_CONG_BBR=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-fq=y
CONFIG_PACKAGE_kmod-sched-bpf=y
CONFIG_PACKAGE_kmod-xdp-sockets=y
CONFIG_PACKAGE_kmod-macvlan=y
CONFIG_PACKAGE_kmod-irqbypass=y  # DPDK依赖的高性能中断
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmemutils=y

# ===== 新增 DPDK 核心组件 =====
CONFIG_PACKAGE_dpdk=y
CONFIG_PACKAGE_numactl=y
CONFIG_PACKAGE_libdpdk=y
CONFIG_PACKAGE_dpdk-tools=y
CONFIG_PACKAGE_dpdk-examples=y
CONFIG_PACKAGE_dpdk-proc-info=y
CONFIG_PACKAGE_kmod-iommu_v2=y

# ===== 新增 DPDK 依赖的内核模块 =====
# UIO框架 (用户空间IO)
CONFIG_PACKAGE_kmod-uio=y
CONFIG_PACKAGE_kmod-uio-pci-generic=y  # PCI设备支持

# 巨页内存支持 (DPDK必需)
CONFIG_PACKAGE_kmod-hugepages=y
CONFIG_KERNEL_HUGETLBFS=y
CONFIG_KERNEL_HUGETLB_PAGE=y

# VFIO安全直通支持 (可选但推荐)
CONFIG_PACKAGE_kmod-vfio=y
CONFIG_PACKAGE_kmod-vfio-pci=y
CONFIG_PACKAGE_kmod-vfio-iommu-type1=y

# 其他硬件支持
CONFIG_PACKAGE_kmod-igc-uio=y  # Intel网卡UIO驱动
CONFIG_PACKAGE_kmod-rte-kni=y  # 内核网络接口

# Ipv6 Support
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_ip6tables-extra=y
CONFIG_PACKAGE_ip6tables-mod-nat=y

# ===== DPDK 性能优化选项 =====
CONFIG_KERNEL_CMA=y  # 连续内存分配器
CONFIG_KERNEL_IOMMU_SUPPORT=y  # IOMMU支持
CONFIG_KERNEL_PCI_IOV=y  # SR-IOV虚拟化