########################################
# OpenWrt x86_64 高性能编译配置
# J4125/I226/千兆软路由优化方案
########################################

########## 目标平台 ##########
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

########## 工具链与编译优化 ##########
# LLVM工具链
CONFIG_LLVM=y
CONFIG_KERNEL_LLVM=y
CONFIG_TOOLCHAIN_LLVM=y
CONFIG_USE_LLD=y                    # LLD链接器加速
CONFIG_USE_LTO=y                    # Thin-LTO链接优化
CONFIG_USE_MOLD=y                   # mold链接器(可选)
CONFIG_USE_GC_SECTIONS=y            # 剔除未用代码

# CPU指令集优化 (根据实际CPU选择)
# CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=native -mtune=native"
# J4125专用: CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=goldmont-plus -mtune=goldmont-plus"

# 安全加固
CONFIG_USE_RELRO=y                  # 重定位只读保护
CONFIG_USE_PIE=y                    # 位置无关可执行
CONFIG_DEBUG_INFO=n                 # 禁用调试符号
CONFIG_DEBUG_KERNEL=n

########## 内核优化 ##########
# CPU调度器 (4核及以下选择)
CONFIG_SCHED_MUQSS=y                # MuQSS调度器
# 或 CONFIG_SCHED_BMQ=y             # BMQ替代方案

# 内存管理
CONFIG_ZSWAP=y                      # 压缩Swap缓存
CONFIG_ZSWAP_COMPRESSOR_LZ4=y       # LZ4低开销压缩
CONFIG_ZRAM=y                       # 内存压缩Swap
CONFIG_ZRAM_WRITEBACK=y             # ZRAM回写安全
CONFIG_COMPACTION=y                 # 内存压缩支持
CONFIG_LRU_GEN=y                    # 改进页面回收
CONFIG_INTEL_IDLE=y                 # Intel C-State控制

# 网络协议栈
CONFIG_TCP_CONG_BBR3=y              # BBRv2拥塞控制
CONFIG_DEFAULT_BBR3=y               # 默认TCP算法
CONFIG_TCP_MD5SIG=y                 # BGP路由支持
CONFIG_NET_SCH_CAKE=y               # CAKE队列管理

# 中断与定时
CONFIG_IRQ_FORCED_THREADING=y       # 中断线程化
CONFIG_HIGH_RES_TIMERS=y            # 高精度定时器

# 多队列网卡
CONFIG_RPS=y                        # 接收包多核分发
CONFIG_RFS_ACCEL=y                  # 智能流导向
CONFIG_XPS=y                        # 发送包多核分发

########## 文件系统 ##########
CONFIG_SQUASHFS_XZ=y                # XZ压缩(解压快)
CONFIG_SQUASHFS_EMBEDDED=y          # 嵌入式优化
CONFIG_SQUASHFS_FRAGMENT_CACHE_SIZE=3
CONFIG_PACKAGE_kmod-fs-overlay=y    # OverlayFS支持

########## BPF/XDP ##########
# 核心BPF支持
CONFIG_BPF=y
CONFIG_BPF_JIT=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_TOOLCHAIN=y
CONFIG_NET_XDP=y

# 网络相关BPF
CONFIG_NETFILTER_XT_MATCH_BPF=y
CONFIG_NETFILTER_XT_TARGET_BPF=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_XDP_SOCKETS=y

# 内核模块
CONFIG_PACKAGE_kmod-xdp-sockets-diag=y
CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-bpf=y
CONFIG_PACKAGE_kmod-xdp=y

########## 多核优化 ##########
CONFIG_PACKAGE_irqbalance=y         # 中断负载均衡
CONFIG_PACKAGE_luci-app-irqbalance=y # 图形化管理

########## NAT/流量分流 ##########
CONFIG_PACKAGE_iptables-mod-tproxy=y      # 透明代理
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y  # NAT扩展
CONFIG_PACKAGE_kmod-nf-flow=y             # 软件分流
CONFIG_PACKAGE_kmod-ipt-offload=y         # Flow Offloading

########## 电源管理 ##########
CONFIG_CPU_FREQ_GOV_ONDEMAND=y      # 动态调频
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y   # 高性能模式

########## 常用应用 ##########
# 系统工具
CONFIG_PACKAGE_htop=y               # 进程监控
CONFIG_PACKAGE_bmon=y               # 带宽监控
CONFIG_PACKAGE_iperf3=y             # 网络测试
CONFIG_PACKAGE_vim-fuller=y         # 增强版vim
CONFIG_PACKAGE_openssh-sftp-server=y

# LuCI应用
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-filemanager=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-oaf=y
CONFIG_PACKAGE_luci-app-onliner=y
CONFIG_PACKAGE_luci-app-statistics=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y

########## 主题美化 ##########
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-theme-infinityfreedom=y
CONFIG_PACKAGE_luci-theme-opentomcat=y

########## IPv6 支持 ##########
CONFIG_PACKAGE_6in4=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_ip6tables-extra=y
CONFIG_PACKAGE_ip6tables-mod-nat=y

########## 固件设置 ##########
CONFIG_TARGET_KERNEL_PARTSIZE=32
CONFIG_TARGET_ROOTFS_PARTSIZE=944
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_TARGZ=y

########## 安全组件 ##########
CONFIG_SECURITY=y
CONFIG_SECURITY_APPARMOR=y         # MAC安全模块
CONFIG_HARDENED_USERCOPY=y         # 防内存越界
CONFIG_STATIC_USERMODEHELPER=y
CONFIG_SYN_COOKIES=y               # SYN Flood防护
CONFIG_PACKAGE_ca-certificates=y   # SSL证书
CONFIG_PACKAGE_openssl-util=y